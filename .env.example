# Copier vers .env (non versionné) — voir docs/README.md
# Utilisé par les scripts Node et pour générer public/js/site-config.json

# URL publique du site (recommandé — ex. domaine FreeDNS ou github.io)
SITE_BASE_URL=https://concours.moo.com

# Compte GitHub (optionnel en local — dérivé de GITHUB_REPOSITORY dans Actions)
GITHUB_OWNER=your-github-username

# Timeout HTTP par requête (ms) — défaut 15000
# HTTP_TIMEOUT_MS=15000
